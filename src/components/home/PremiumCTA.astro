---
import { Image } from 'astro:assets';
// Você pode usar a imagem da frota que geramos ou manter a de background do template
import ctaBgImg from '@assets/photo-1553413077-190dd305871c.jpg';
---

<section class='relative py-32 overflow-hidden'>
  <div class='absolute inset-0'>
    <Image
      src={ctaBgImg}
      alt='Estoque e Logística Wex'
      class='w-full h-full object-cover'
      width={2070}
      height={1380}
    />
    <div
      class='absolute inset-0 bg-linear-to-r from-blue-900/95 to-slate-900/95'
    >
    </div>
  </div>

  <div class='container mx-auto px-4 sm:px-6 lg:px-8 relative z-10'>
    <div class='max-w-4xl mx-auto text-center text-white'>
      <div
        class='inline-block px-4 py-2 mb-6 bg-white/10 backdrop-blur-sm text-white text-sm font-semibold rounded-full border border-white/20'
      >
        Atendimento Imediato
      </div>
      <h2 class='text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight'>
        Pronto para fazer sua <span
          class='text-transparent bg-clip-text bg-linear-to-r from-blue-400 to-teal-400'
          >Cotação?</span
        >
      </h2>
      <p
        class='text-xl md:text-2xl text-slate-200 mb-12 max-w-2xl mx-auto leading-relaxed'
      >
        Consulte nosso estoque agora mesmo. Garantimos agilidade na resposta e o
        melhor custo-benefício para sua frota.
      </p>

      <div class='flex flex-col sm:flex-row gap-6 justify-center mb-16'>
        <a
          href='https://wa.me/5512991640870'
          target='_blank'
          class='inline-flex items-center justify-center px-8 py-4 text-lg font-bold text-white bg-green-600 hover:bg-green-700 rounded-lg shadow-2xl hover:shadow-3xl transition-all group'
        >
          Chamar no WhatsApp
          <svg
            class='w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform'
            fill='currentColor'
            viewBox='0 0 24 24'
          >
            <path
              d='M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z'
            ></path>
          </svg>
        </a>

        <a
          href='tel:+551143784521'
          class='inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white border-2 border-white hover:bg-white/10 rounded-lg shadow-2xl hover:shadow-3xl transition-all group'
        >
          Ligar: (11) 4378-4521
          <svg
            class='w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform'
            fill='none'
            stroke='currentColor'
            viewBox='0 0 24 24'
          >
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
              stroke-width='2'
              d='M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z'
            ></path>
          </svg>
        </a>
      </div>

      <div class='grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto'>
        <div
          class='backdrop-blur-md bg-white/5 rounded-xl p-6 hover:bg-white/10 transition-all border border-white/10 hover:border-blue-400/50 group text-center'
        >
          <div class='flex justify-center mb-3'>
            <svg
              class='w-8 h-8 text-blue-400 group-hover:text-white transition-colors'
              fill='none'
              stroke='currentColor'
              viewBox='0 0 24 24'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                stroke-width='2'
                d='M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z'
              ></path>
            </svg>
          </div>
          <div class='text-2xl font-bold mb-1 text-white'>Expertise</div>
          <div
            class='text-sm text-slate-300 group-hover:text-blue-200 transition-colors'
          >
            Vasta Experiência
          </div>
        </div>

        <div
          class='backdrop-blur-md bg-white/5 rounded-xl p-6 hover:bg-white/10 transition-all border border-white/10 hover:border-blue-400/50 group text-center'
        >
          <div class='flex justify-center mb-3'>
            <svg
              class='w-8 h-8 text-blue-400 group-hover:text-white transition-colors'
              fill='none'
              stroke='currentColor'
              viewBox='0 0 24 24'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                stroke-width='2'
                d='M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z'
              ></path>
            </svg>
          </div>
          <div class='text-2xl font-bold mb-1 text-white'>Premium</div>
          <div
            class='text-sm text-slate-300 group-hover:text-blue-200 transition-colors'
          >
            Peças de 1ª Linha
          </div>
        </div>

        <div
          class='backdrop-blur-md bg-white/5 rounded-xl p-6 hover:bg-white/10 transition-all border border-white/10 hover:border-blue-400/50 group text-center'
        >
          <div class='flex justify-center mb-3'>
            <svg
              class='w-8 h-8 text-blue-400 group-hover:text-white transition-colors'
              fill='none'
              stroke='currentColor'
              viewBox='0 0 24 24'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                stroke-width='2'
                d='M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z'></path>
            </svg>
          </div>
          <div class='text-2xl font-bold mb-1 text-white'>Agilidade</div>
          <div
            class='text-sm text-slate-300 group-hover:text-blue-200 transition-colors'
          >
            Orçamento Rápido
          </div>
        </div>

        <div
          class='backdrop-blur-md bg-white/5 rounded-xl p-6 hover:bg-white/10 transition-all border border-white/10 hover:border-blue-400/50 group text-center'
        >
          <div class='flex justify-center mb-3'>
            <svg
              class='w-8 h-8 text-blue-400 group-hover:text-white transition-colors'
              fill='none'
              stroke='currentColor'
              viewBox='0 0 24 24'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                stroke-width='2'
                d='M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z'
              ></path>
            </svg>
          </div>
          <div class='text-2xl font-bold mb-1 text-white'>Nacional</div>
          <div
            class='text-sm text-slate-300 group-hover:text-blue-200 transition-colors'
          >
            Envio para todo Brasil
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
