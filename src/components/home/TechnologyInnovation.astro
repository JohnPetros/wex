---
import { Image } from 'astro:assets';
// Substitua pela imagem da frota ou caminhão que geramos anteriormente
import truckImg from '@assets/photo-1601584115197-04ecc0da31d7.jpg';

interface Differential {
  title: string;
  description: string;
  iconGradient: string;
  iconPath: string;
}

const differentials: Differential[] = [
  {
    title: 'Qualidade Garantida',
    description:
      'Distribuímos apenas materiais de altíssima qualidade para garantir a durabilidade que sua frota precisa.',
    iconGradient: 'from-blue-500 to-blue-600',
    // Ícone Award/Medalha
    iconPath:
      'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
  },
  {
    title: 'Expansão Sustentável',
    description:
      'Crescimento estratégico e investimento contínuo para atender a alta demanda do mercado.',
    iconGradient: 'from-teal-500 to-teal-600',
    // Ícone TrendingUp/Gráfico
    iconPath: 'M23 6l-9.5 9.5-5-5L1 18',
  },
  {
    title: 'Vasta Experiência',
    description:
      'Anos de atuação no segmento pesado, oferecendo segurança e confiança a cada pedido.',
    iconGradient: 'from-blue-500 to-blue-600',
    // Ícone Shield/Escudo
    iconPath: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  },
  {
    title: 'Atendimento Próximo',
    description:
      'Equipe pronta para tirar dúvidas e fechar orçamentos rapidamente pelo WhatsApp.',
    iconGradient: 'from-teal-500 to-teal-600',
    // Ícone Message/Chat
    iconPath:
      'M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z',
  },
];
---

<section
  class='py-24 bg-linear-to-b from-slate-900 via-slate-800 to-slate-900 relative overflow-hidden'
>
  <div class='absolute inset-0 opacity-10'>
    <div
      class='absolute inset-0'
      style='background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;'
    >
    </div>
  </div>

  <div class='container mx-auto px-4 sm:px-6 lg:px-8 relative z-10'>
    <div class='grid grid-cols-1 lg:grid-cols-2 gap-12 items-center'>
      <div>
        <div
          class='inline-block px-4 py-2 mb-4 bg-blue-900/30 border border-blue-800 backdrop-blur-sm text-blue-400 text-sm font-semibold rounded-full'
        >
          SOBRE A WEX
        </div>
        <h2 class='text-4xl md:text-5xl font-bold text-white mb-6'>
          Impulsionando o transporte com <span
            class='text-transparent bg-clip-text bg-linear-to-r from-blue-400 to-teal-400'
            >Excelência</span
          >
        </h2>
        <p class='text-xl text-slate-300 mb-8 leading-relaxed'>
          A WEX Distribuidora atua com grande afinco no mercado de implementos.
          Nosso foco não é apenas vender peças, mas garantir que seu caminhão
          continue rodando com peças de reposição confiáveis.
        </p>

        <div class='space-y-6'>
          {
            differentials.map(item => (
              <div class='flex items-start group'>
                <div
                  class={`shrink-0 w-12 h-12 rounded-lg bg-linear-to-br ${item.iconGradient} flex items-center justify-center mr-4 group-hover:scale-110 transition-transform`}
                >
                  <svg
                    class='w-6 h-6 text-white'
                    fill='none'
                    stroke='currentColor'
                    viewBox='0 0 24 24'
                  >
                    <path
                      stroke-linecap='round'
                      stroke-linejoin='round'
                      stroke-width='2'
                      d={item.iconPath}
                    />
                  </svg>
                </div>
                <div>
                  <h3 class='text-xl font-semibold text-white mb-2'>
                    {item.title}
                  </h3>
                  <p class='text-slate-400 leading-relaxed'>
                    {item.description}
                  </p>
                </div>
              </div>
            ))
          }
        </div>

        <div class='mt-10'>
          <a
            href='https://whats.link/wexdistribuidora'
            class='inline-flex items-center px-6 py-3 text-base font-semibold text-white bg-linear-to-r from-blue-600 to-teal-600 hover:from-blue-700 hover:to-teal-700 rounded-lg shadow-lg hover:shadow-xl transition-all group'
          >
            Falar com Vendedor
            <svg
              class='w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform'
              fill='none'
              stroke='currentColor'
              viewBox='0 0 24 24'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                stroke-width='2'
                d='M17 8l4 4m0 0l-4 4m4-4H3'></path>
            </svg>
          </a>
        </div>
      </div>

      <div class='relative'>
        <div
          class='relative rounded-2xl overflow-hidden shadow-2xl border border-slate-700 bg-slate-800'
        >
          <Image
            src={truckImg}
            alt='Frota WEX Distribuidora'
            class='w-full h-full object-cover opacity-90 hover:scale-105 transition-transform duration-700'
            width={1200}
            height={800}
          />
          <div
            class='absolute inset-0 bg-linear-to-br from-slate-900/60 via-transparent to-slate-900/60'
          >
          </div>

          {/* Central Badge (Optional) */}
          <div
            class='absolute inset-0 flex items-center justify-center pointer-events-none'
          >
            <div
              class='bg-slate-900/80 backdrop-blur-xl p-4 rounded-full border border-blue-500/30 shadow-2xl animate-fade-in-up'
            >
              <svg
                class='w-8 h-8 text-blue-400'
                fill='none'
                stroke='currentColor'
                viewBox='0 0 24 24'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  stroke-width='2'
                  d='M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z'></path>
              </svg>
            </div>
          </div>
        </div>

        <div
          class='absolute -top-4 -right-4 bg-white rounded-lg p-4 shadow-xl z-20 animate-pulse'
        >
          <div class='flex items-center'>
            <div class='w-3 h-3 rounded-full bg-green-500 mr-2'></div>
            <span class='text-sm font-semibold text-slate-900'
              >Estoque Disponível</span
            >
          </div>
        </div>
        <div
          class='absolute -bottom-4 -left-4 bg-white rounded-lg p-4 shadow-xl z-20 animate-pulse'
          style='animation-delay: 0.5s;'
        >
          <div class='flex items-center'>
            <div class='w-3 h-3 rounded-full bg-blue-500 mr-2'></div>
            <span class='text-sm font-semibold text-slate-900'
              >Atendimento Rápido</span
            >
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
